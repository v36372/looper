# Server-only Lakebed environment for Looper.
# Copy this file to `.env.lakebed.server` and replace the placeholders.
# Never commit real secrets. `.env.lakebed.server` is gitignored.
#
# ALLOWED_EMAILS
#   Comma-separated Google account emails permitted to view the board.
#   Matching trims whitespace and lowercases both sides.
#   Example: person@example.com, other@example.com
#
# INGEST_TOKEN
#   High-entropy bearer secret for PUT /api/v1/snapshot.
#   Generate with: openssl rand -hex 32
#   Never put this value in client code, logs, responses, or the repository.

ALLOWED_EMAILS=person@example.com,other@example.com
INGEST_TOKEN=replace-with-high-entropy-secret
